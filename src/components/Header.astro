---
---
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<header class="header">
  <div>
    <div class="brand">Mis<em>Tareas</em></div>
    <div class="tagline">Organizá tu día, una tarea a la vez.</div>
  </div>
  <div class="stats">
    <div class="stat"><span class="stat-n" id="s-t">0</span><span class="stat-l">Total</span></div>
    <div class="stat"><span class="stat-n" id="s-p">0</span><span class="stat-l">Pend.</span></div>
    <div class="stat"><span class="stat-n" id="s-d">0</span><span class="stat-l">Hechas</span></div>
  </div>
</header>
<div class="prog-wrap"><div class="prog-fill" id="prog"></div></div>

<style>
  .header {
    padding: 2.5rem 2.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    background: #111; /* Aseguramos el fondo */
  }
  .brand { font-size: 2rem; font-weight: 700; color: #fff; letter-spacing: -1px; }
  .brand em { font-style: normal; color: #e8ff47; }
  .tagline { font-size: 0.82rem; color: #444; margin-top: 0.25rem; font-weight: 300; }
  .stats { display: flex; gap: 0.75rem; }
  .stat {
    display: flex; flex-direction: column; align-items: center;
    background: #181818; border: 1px solid #222; border-radius: 12px;
    padding: 0.6rem 1.1rem; min-width: 64px;
  }
  .stat-n { font-size: 1.5rem; font-weight: 700; color: #e8ff47; line-height: 1; }
  .stat-l { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1.5px; color: #444; margin-top: 3px; }
  .prog-wrap { height: 2px; background: #1a1a1a; }
  .prog-fill { height: 100%; background: #e8ff47; width: 0%; transition: width 0.5s cubic-bezier(.4,0,.2,1); }
</style>