---
---
 
<main class="main">
 
  <div class="input-card">
    <div class="input-row">
      <input id="inp" type="text" placeholder="¿Qué tenés que hacer hoy?" maxlength="80" />
      <button id="btn">+ Agregar</button>
    </div>
    <div class="err" id="err">Escribí una tarea primero.</div>
  </div>
 
  <div class="section">
    <div class="sec-head">
      <span class="sec-title">Pendientes</span>
      <span class="badge" id="c-p">0</span>
    </div>
    <ul id="lp"><li class="empty">No hay tareas todavía. ¡Agregá una!</li></ul>
  </div>
 
  <div class="section">
    <div class="sec-head">
      <span class="sec-title">Completadas</span>
      <span class="badge" id="c-d">0</span>
    </div>
    <ul id="ld"><li class="empty">Todavía no completaste ninguna.</li></ul>
  </div>
 
</main>
 
<style is:global>
 
  /* ── Variables modo oscuro (default) ── */
  body {
    --bg:         #111;
    --card-bg:    #181818;
    --item-bg:    #111;
    --item-hover: #141414;
    --border:     #222;
    --border-dim: #1e1e1e;
    --text:       #ccc;
    --text-muted: #444;
    --text-cross: #333;
    --placeholder:#333;
    --empty:      #2a2a2a;
    --badge-bg:   #222;
    --badge-text: #555;
    --err:        #ff5555;
    --stat-bg:    #181818;
    --header-bg:  #111;
    --footer-bg:  #0f0f0f;
    --footer-text:#333;
    --prog-bg:    #1a1a1a;
    --brand:      #fff;
    --muted:      #444;
    transition: background 0.3s;
  }
 
  /* ── Variables modo claro ── */
  body.light {
    --bg:         #f4f4f0;
    --card-bg:    #fff;
    --item-bg:    #f9f9f7;
    --item-hover: #f0f0ec;
    --border:     #e0e0d8;
    --border-dim: #e8e8e0;
    --text:       #222;
    --text-muted: #999;
    --text-cross: #bbb;
    --placeholder:#aaa;
    --empty:      #ccc;
    --badge-bg:   #eee;
    --badge-text: #999;
    --err:        #e03030;
    --stat-bg:    #f0f0ec;
    --header-bg:  #fff;
    --footer-bg:  #f0f0ec;
    --footer-text:#aaa;
    --prog-bg:    #e0e0d8;
    --brand:      #111;
    --muted:      #999;
  }
 
  body { background: var(--bg); }
 
  /* ── Layout ── */
  .main {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    flex: 1;
  }
 
  /* ── Cards ── */
  .input-card, .section {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    transition: background 0.3s, border-color 0.3s;
  }
 
  .input-card { padding: 2.5rem; }
 
  /* ── Input ── */
  .input-row { display: flex; gap: 1rem; }
 
  .input-row input {
    flex: 1;
    background: var(--item-bg);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    font-size: 1.1rem;
    color: var(--text);
    outline: none;
    font-family: 'Outfit', sans-serif;
    transition: border-color 0.2s, background 0.3s;
  }
 
  .input-row input::placeholder { color: var(--placeholder); }
  .input-row input:focus { border-color: #e8ff47; }
 
  .input-row button {
    background: #e8ff47;
    color: #111;
    border: none;
    border-radius: 12px;
    padding: 0 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    transition: background 0.15s, transform 0.15s;
    white-space: nowrap;
  }
 
  .input-row button:hover { background: #f2ff70; transform: scale(1.02); }
  .input-row button:active { transform: scale(0.97); }
 
  .err { font-size: 0.9rem; color: var(--err); margin-top: 0.5rem; display: none; }
 
  /* ── Secciones ── */
  .sec-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border-dim);
  }
 
  .sec-title {
    font-size: 0.85rem; font-weight: 600;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--text-muted);
  }
 
  .badge {
    background: var(--badge-bg);
    color: var(--badge-text);
    border-radius: 99px; padding: 4px 14px;
    font-size: 0.8rem; font-weight: 600;
    transition: background 0.3s, color 0.3s;
  }
 
  .badge.has-items { background: rgba(232, 255, 71, 0.15); color: #e8ff47; }
 
  /* ── Lista ── */
  ul { list-style: none; padding: 1.2rem; display: flex; flex-direction: column; gap: 0.8rem; }
 
  .empty {
    text-align: center; padding: 2.5rem;
    color: var(--empty); font-size: 1.1rem; font-style: italic;
  }
 
  /* ── Items ── */
  .item {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.2rem 1.5rem;
    background: var(--item-bg);
    border: 1px solid var(--border-dim);
    border-radius: 14px;
    transition: background 0.2s, border-color 0.2s;
  }
 
  .item:hover { background: var(--item-hover); }
 
  /* ── Botones check y eliminar ── */
  button.check, button.btn-x {
    width: 38px !important; height: 38px !important;
    background: transparent !important;
    border: none !important;
    cursor: pointer;
    display: flex !important;
    align-items: center; justify-content: center;
    padding: 0 !important;
    transition: transform 0.2s;
    flex-shrink: 0;
  }
 
  button.check:hover, button.btn-x:hover { transform: scale(1.2); }
  button.check { color: #00ff88 !important; }
  button.btn-x { color: #ff4444 !important; font-size: 24px; font-weight: bold; }
 
  .txt { flex: 1; font-size: 1.1rem; color: var(--text); transition: color 0.3s; }
  .item.completada .txt { text-decoration: line-through; color: var(--text-cross); }
 
</style>
 
<script>
  let pend = [];
  let done = [];
 
  const inp = document.getElementById('inp');
  const btn = document.getElementById('btn');
  const err = document.getElementById('err');
  const lp  = document.getElementById('lp');
  const ld  = document.getElementById('ld');
 
  const checkSVG = `<svg viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;pointer-events:none"><polyline points="1.5,5.5 4.5,8.5 9.5,2.5" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
 
  function esc(s) {
    const d = document.createElement('div');
    d.appendChild(document.createTextNode(s));
    return d.innerHTML;
  }
 
  function actualizarStats() {
    const total  = pend.length + done.length;
    const hechas = done.length;
 
    const cp = document.getElementById('c-p');
    const cd = document.getElementById('c-d');
    if (cp) { cp.textContent = pend.length; cp.className = 'badge' + (pend.length ? ' has-items' : ''); }
    if (cd) { cd.textContent = hechas;      cd.className = 'badge' + (hechas ? ' has-items' : ''); }
 
    if (document.getElementById('s-t')) document.getElementById('s-t').textContent = total;
    if (document.getElementById('s-p')) document.getElementById('s-p').textContent = pend.length;
    if (document.getElementById('s-d')) document.getElementById('s-d').textContent = hechas;
 
    const prog = document.getElementById('prog');
    if (prog) prog.style.width = (total ? Math.round(hechas / total * 100) : 0) + '%';
  }
 
  function render() {
    lp.innerHTML = pend.length
      ? pend.map((t, i) => `
          <li class="item">
            <button class="check" data-a="ok" data-i="${i}">${checkSVG}</button>
            <span class="txt">${esc(t)}</span>
            <button class="btn-x" data-a="dp" data-i="${i}">✕</button>
          </li>`).join('')
      : '<li class="empty">No hay tareas todavía.</li>';
 
    ld.innerHTML = done.length
      ? done.map((t, i) => `
          <li class="item completada">
            <span class="txt">${esc(t)}</span>
            <button class="btn-x" data-a="dd" data-i="${i}">✕</button>
          </li>`).join('')
      : '<li class="empty">Todavía no completaste ninguna.</li>';
 
    actualizarStats();
  }
 
  function agregarTarea() {
    const v = inp.value.trim();
    if (!v) { err.style.display = 'block'; return; }
    err.style.display = 'none';
    pend.push(v);
    inp.value = '';
    render();
  }
 
  btn.addEventListener('click', agregarTarea);
  inp.addEventListener('keydown', (e) => { if (e.key === 'Enter') agregarTarea(); });
 
  [lp, ld].forEach(lista => {
    lista.addEventListener('click', (e) => {
      const el = e.target.closest('[data-a]');
      if (!el) return;
      const i = parseInt(el.dataset.i);
      const action = el.dataset.a;
      if (action === 'ok')      done.push(pend.splice(i, 1)[0]);
      else if (action === 'dp') pend.splice(i, 1);
      else if (action === 'dd') done.splice(i, 1);
      render();
    });
  });
 
  render();
</script>