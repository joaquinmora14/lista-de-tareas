---
---

<main class="main">
  <div class="input-card">
    <div class="input-row">
      <input id="inp" type="text" placeholder="¿Qué tenés que hacer hoy?" maxlength="80" />
      <button id="btn">+ Agregar</button>
    </div>
    <div class="err" id="err">Escribí una tarea primero.</div>
  </div>

  <div class="section">
    <div class="sec-head">
      <span class="sec-title">Pendientes</span>
      <span class="badge" id="c-p">0</span>
    </div>
    <ul id="lp"><li class="empty">No hay tareas todavía. ¡Agregá una!</li></ul>
  </div>

  <div class="section">
    <div class="sec-head">
      <span class="sec-title">Completadas</span>
      <span class="badge" id="c-d">0</span>
    </div>
    <ul id="ld"><li class="empty">Todavía no completaste ninguna.</li></ul>
  </div>
</main>

<style is:global>
  /* El is:global es la clave para que el Inspector de Chrome deje de poner fondos grises */
  
  .main {
    max-width: 660px;
    width: 100%;
    margin: 2.5rem auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    flex: 1;
  }

  .input-card, .section {
    background: #181818;
    border: 1px solid #222;
    border-radius: 16px;
    overflow: hidden;
  }

  .input-card { padding: 1.5rem; }

  .input-row { display: flex; gap: 0.6rem; }
  .input-row input {
    flex: 1; background: #111; border: 1.5px solid #272727; border-radius: 10px;
    padding: 0.8rem 1rem; color: #f0f0f0; outline: none; font-family: 'Outfit', sans-serif;
  }
  .input-row input:focus { border-color: #e8ff47; }

  .input-row button {
    background: #e8ff47; color: #111; border: none; border-radius: 10px;
    padding: 0 1.4rem; font-weight: 700; cursor: pointer; font-family: 'Outfit', sans-serif;
  }

  .sec-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem 1.4rem; border-bottom: 1px solid #1e1e1e;
  }
  .sec-title { font-size: 0.7rem; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase; color: #444; }
  
  .badge { background: #222; color: #555; border-radius: 99px; padding: 2px 10px; font-size: 0.68rem; }
  .badge.has-items { background: rgba(232, 255, 71, 0.1); color: #e8ff47; }

  ul { list-style: none; padding: 0.75rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .empty { text-align: center; padding: 1.5rem; color: #2a2a2a; font-size: 0.85rem; font-style: italic; }

  .item {
    display: flex; align-items: center; gap: 0.75rem; padding: 0.8rem 0.9rem;
    background: #111; border: 1px solid #1e1e1e; border-radius: 10px;
  }

  /* ── AQUÍ EL RESET PARA QUE NO HAYA FONDOS NI BORDES ── */
  button.check, button.btn-x {
    width: 32px !important;
    height: 32px !important;
    background: transparent !important;
    background-color: transparent !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    cursor: pointer;
    display: flex !important;
    align-items: center;
    justify-content: center;
    padding: 0 !important;
    appearance: none !important;
    -webkit-appearance: none !important;
    transition: transform 0.2s;
  }

  button.check:hover, button.btn-x:hover { transform: scale(1.2); }

  /* Colores Neón Intensos */
  button.check { color: #00ff88 !important; } 
  button.btn-x { color: #ff4444 !important; font-size: 22px; font-weight: bold; }

  .txt { flex: 1; font-size: 0.95rem; color: #ccc; }
  .item.completada .txt { text-decoration: line-through; color: #444; }
  .err { font-size: 0.78rem; color: #ff5555; margin-top: 0.5rem; display: none; }
</style>

<script>
  let pend = [];
  let done = [];

  const inp = document.getElementById('inp');
  const btn = document.getElementById('btn');
  const err = document.getElementById('err');
  const lp = document.getElementById('lp');
  const ld = document.getElementById('ld');

  // SVG más grueso para que el verde se note sobre el fondo oscuro
  const checkSVG = `<svg viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;pointer-events:none"><polyline points="1.5,5.5 4.5,8.5 9.5,2.5" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

  function esc(s) {
    const d = document.createElement('div');
    d.appendChild(document.createTextNode(s));
    return d.innerHTML;
  }

  function actualizarStats() {
    const total = pend.length + done.length;
    const hechas = done.length;
    
    const cp = document.getElementById('c-p');
    const cd = document.getElementById('c-d');
    if(cp) { cp.textContent = pend.length; cp.className = 'badge' + (pend.length ? ' has-items' : ''); }
    if(cd) { cd.textContent = hechas; cd.className = 'badge' + (hechas ? ' has-items' : ''); }

    if(document.getElementById('s-t')) document.getElementById('s-t').textContent = total;
    if(document.getElementById('s-p')) document.getElementById('s-p').textContent = pend.length;
    if(document.getElementById('s-d')) document.getElementById('s-d').textContent = hechas;

    if(document.getElementById('prog')) {
        const pct = total ? Math.round(hechas / total * 100) : 0;
        document.getElementById('prog').style.width = pct + '%';
    }
  }

  function render() {
    lp.innerHTML = pend.length
      ? pend.map((t, i) => `
          <li class="item">
            <button class="check" data-a="ok" data-i="${i}">${checkSVG}</button>
            <span class="txt">${esc(t)}</span>
            <button class="btn-x" data-a="dp" data-i="${i}">✕</button>
          </li>`).join('')
      : '<li class="empty">No hay tareas todavía.</li>';

    ld.innerHTML = done.length
      ? done.map((t, i) => `
          <li class="item completada">
            <span class="txt">${esc(t)}</span>
            <button class="btn-x" data-a="dd" data-i="${i}">✕</button>
          </li>`).join('')
      : '<li class="empty">Todavía no completaste ninguna.</li>';

    actualizarStats();
  }

  function agregarTarea() {
    const v = inp.value.trim();
    if (!v) { err.style.display = 'block'; return; }
    err.style.display = 'none';
    pend.push(v);
    inp.value = '';
    render();
  }

  btn.addEventListener('click', agregarTarea);
  inp.addEventListener('keydown', (e) => { if (e.key === 'Enter') agregarTarea(); });

  [lp, ld].forEach(lista => {
    lista.addEventListener('click', (e) => {
      const el = e.target.closest('[data-a]');
      if (!el) return;
      const i = parseInt(el.dataset.i);
      const action = el.dataset.a;
      if (action === 'ok') done.push(pend.splice(i, 1)[0]);
      else if (action === 'dp') pend.splice(i, 1);
      else if (action === 'dd') done.splice(i, 1);
      render();
    });
  });

  render();
</script>