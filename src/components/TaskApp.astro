<section class="app">
 
  <!-- Input para agregar tarea -->
  <div class="input-zone">
    <input id="input-tarea" type="text" placeholder="¿Qué tenés que hacer hoy?" maxlength="80" />
    <button id="btn-agregar">+ Agregar</button>
    <span class="error" id="error-msg">Escribí una tarea primero.</span>
  </div>
 
  <!-- Tareas pendientes -->
  <p class="label">Pendientes <span id="count-pend" class="badge">0</span></p>
  <ul id="lista-pendientes">
    <li class="vacia">No hay tareas todavía. ¡Agregá una!</li>
  </ul>
 
  <hr />
 
  <!-- Tareas completadas -->
  <p class="label">Completadas <span id="count-done" class="badge">0</span></p>
  <ul id="lista-completadas">
    <li class="vacia">Todavía no completaste ninguna.</li>
  </ul>
 
</section>
 
<style>
  /* Reset y base */
  * { box-sizing: border-box; margin: 0; padding: 0; }
 
  .app {
    background: #0f0f0f;
    color: #f0ede8;
    font-family: 'DM Sans', sans-serif;
    padding: 2rem;
    max-width: 680px;
    margin: 0 auto;
    min-height: 60vh;
  }
 
  /* Input */
  .input-zone {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
    position: relative;
  }
 
  input {
    flex: 1;
    min-width: 200px;
    background: #171717;
    border: 1px solid #2a2a2a;
    border-radius: 10px;
    padding: 0.85rem 1.1rem;
    color: #f0ede8;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
  }
 
  input:focus { border-color: #c8f55a; }
  input::placeholder { color: #444; }
 
  button#btn-agregar {
    background: #c8f55a;
    color: #0f0f0f;
    border: none;
    border-radius: 10px;
    padding: 0 1.4rem;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
  }
 
  button#btn-agregar:hover { background: #d6ff6a; transform: scale(1.03); }
 
  .error {
    position: absolute;
    bottom: -1.4rem;
    left: 0;
    font-size: 0.78rem;
    color: #ff6b6b;
    display: none;
  }
 
  /* Labels y badges */
  .label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
 
  .badge {
    background: #1e1e1e;
    color: #666;
    border-radius: 99px;
    padding: 1px 8px;
    font-size: 0.68rem;
  }
 
  hr { border: none; border-top: 1px solid #1a1a1a; margin: 1rem 0 2rem; }
 
  /* Listas */
  ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2rem; }
 
  .vacia {
    padding: 1.2rem;
    border: 1px dashed #222;
    border-radius: 10px;
    text-align: center;
    color: #3a3a3a;
    font-style: italic;
    font-size: 0.85rem;
  }
 
  /* Items de tarea */
  .item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #171717;
    border: 1px solid #1e1e1e;
    border-radius: 10px;
    padding: 0.8rem 1rem;
    animation: entrar 0.28s ease;
    transition: transform 0.15s;
  }
 
  @keyframes entrar {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
 
  .item:hover { transform: translateX(2px); }
 
  /* Círculo de check */
  .check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 1.5px solid #333;
    flex-shrink: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s;
    background: transparent;
    font-size: 11px;
    color: transparent;
  }
 
  .check:hover { border-color: #c8f55a; }
  .check.hecho { background: #c8f55a; border-color: #c8f55a; color: #0f0f0f; }
 
  /* Texto */
  .texto { flex: 1; font-size: 0.92rem; color: #d0cdc8; }
  .item.completada .texto { text-decoration: line-through; color: #3a3a3a; }
 
  /* Botón eliminar */
  .btn-del {
    background: #1e1e1e;
    border: none;
    border-radius: 6px;
    width: 28px;
    height: 28px;
    cursor: pointer;
    color: #555;
    font-size: 13px;
    opacity: 0;
    transition: opacity 0.2s, background 0.15s, color 0.15s;
  }
 
  .item:hover .btn-del { opacity: 1; }
  .btn-del:hover { background: #3a1a1a; color: #ff6b6b; }
</style>
 
<script>
  // Estado
  let pendientes = [];
  let completadas = [];
 
  // Elementos del DOM
  const inputTarea   = document.getElementById('input-tarea');
  const btnAgregar   = document.getElementById('btn-agregar');
  const errorMsg     = document.getElementById('error-msg');
  const listaPend    = document.getElementById('lista-pendientes');
  const listaComp    = document.getElementById('lista-completadas');
 
  // ── Helpers ──────────────────────────────────────────
 
  // Escapa HTML para evitar inyecciones
  function esc(str) {
    const d = document.createElement('div');
    d.appendChild(document.createTextNode(str));
    return d.innerHTML;
  }
 
  // Actualiza stats del Header y barra de progreso
  function actualizarStats() {
    const total = pendientes.length + completadas.length;
    const pct = total === 0 ? 0 : Math.round((completadas.length / total) * 100);
 
    document.getElementById('stat-total').textContent = total;
    document.getElementById('stat-pend').textContent  = pendientes.length;
    document.getElementById('stat-done').textContent  = completadas.length;
    document.getElementById('count-pend').textContent = pendientes.length;
    document.getElementById('count-done').textContent = completadas.length;
    document.getElementById('progress-bar').style.width = pct + '%';
  }
 
  // ── Render ───────────────────────────────────────────
 
  function render() {
    // Pendientes
    listaPend.innerHTML = pendientes.length === 0
      ? '<li class="vacia">No hay tareas todavía. ¡Agregá una!</li>'
      : pendientes.map((t, i) => `
          <li class="item">
            <div class="check" data-accion="completar" data-i="${i}">✓</div>
            <span class="texto">${esc(t)}</span>
            <button class="btn-del" data-accion="borrar-pend" data-i="${i}">✕</button>
          </li>`).join('');
 
    // Completadas
    listaComp.innerHTML = completadas.length === 0
      ? '<li class="vacia">Todavía no completaste ninguna.</li>'
      : completadas.map((t, i) => `
          <li class="item completada">
            <div class="check hecho">✓</div>
            <span class="texto">${esc(t)}</span>
            <button class="btn-del" data-accion="borrar-comp" data-i="${i}">✕</button>
          </li>`).join('');
 
    actualizarStats();
  }
 
  // ── Acciones ─────────────────────────────────────────
 
  function agregar() {
    const texto = inputTarea.value.trim();
    if (!texto) { errorMsg.style.display = 'block'; return; }
    errorMsg.style.display = 'none';
    pendientes.push(texto);
    inputTarea.value = '';
    render();
  }
 
  // Un solo listener por lista (delegación de eventos)
  listaPend.addEventListener('click', (e) => {
    const el = e.target.closest('[data-accion]');
    if (!el) return;
    const i = parseInt(el.dataset.i);
    if (el.dataset.accion === 'completar') {
      completadas.push(pendientes.splice(i, 1)[0]);
    } else {
      pendientes.splice(i, 1);
    }
    render();
  });
 
  listaComp.addEventListener('click', (e) => {
    const el = e.target.closest('[data-accion]');
    if (!el) return;
    completadas.splice(parseInt(el.dataset.i), 1);
    render();
  });
 
  btnAgregar.addEventListener('click', agregar);
  inputTarea.addEventListener('keydown', (e) => e.key === 'Enter' && agregar());
 
  // Render inicial
  render();
</script>