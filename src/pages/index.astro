---
import Header from '../components/Header.astro';
import TaskApp from '../components/TaskApp.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MisTareas</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <div class="content-wrapper">
      <TaskApp />
    </div>
    <Footer />
  </body>
</html>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  /* ── Modo oscuro (default) ── */
  body {
    --bg:            #111;
    --header-bg:     #111;
    --footer-bg:     #0f0f0f;
    --footer-text:   #444;
    --footer-border: #1a1a1a;
    --card-bg:       #181818;
    --item-bg:       #111;
    --item-hover:    #161616;
    --border:        #222;
    --border-dim:    #1e1e1e;
    --text:          #ddd;
    --text-muted:    #555;
    --text-strike:   #3a3a3a;
    --placeholder:   #333;
    --empty-text:    #2a2a2a;
    --badge-bg:      #1e1e1e;
    --badge-text:    #555;
    --brand-color:   #fff;
    --stat-bg:       #181818;
    --stat-border:   #333;
    --prog-bg:       #1a1a1a;
    --input-bg:      #111;

    font-family: 'Outfit', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    transition: background 0.3s;
  }

  /* ── Modo claro (Cálido) ── */
  body.light {
    --bg:            #f0ede8;
    --header-bg:     #f0ede8; /* Antes era oscuro, ahora es cálido */
    --footer-bg:     #f0ede8; 
    --footer-text:   #888;
    --footer-border: #e8e4de;
    --card-bg:       #fff;
    --item-bg:       #faf9f7;
    --item-hover:    #f3f1ee;
    --border:        #e8e4de;
    --border-dim:    #ede9e3;
    --text:          #1a1a1a;
    --text-muted:    #999;
    --text-strike:   #bbb;
    --placeholder:   #bbb;
    --empty-text:    #ccc;
    --badge-bg:      #f0ede8;
    --badge-text:    #aaa;
    --brand-color:   #1a1a1a; /* Nombre de la app en oscuro */
    --stat-bg:       #e8e4de; /* Stats claros */
    --stat-border:   #d8d4ce;
    --prog-bg:       #e8e4de;
    --input-bg:      #f8f6f2;
  }

  html, body { height: 100%; }

  .content-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    transition: background 0.3s;
  }
</style>